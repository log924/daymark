{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "daymark-daily",
  "main": "./worker/scheduled.ts",
  "compatibility_date": "2026-07-18",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "daymark-db",
      "database_id": "eb1b83fe-e7a6-4f4c-b185-9efa6d5900d5"
    }
  ],
  "triggers": {
    "crons": ["0 22 * * *"]
  },
  "observability": {
    "enabled": true
  }
}
